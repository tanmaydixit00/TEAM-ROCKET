# ─── Firebase ─────────────────────────────────────────────────────────────────
# Copy these values from your Firebase project console
# Project Settings → General → Your apps → Web app → SDK setup & configuration
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# ─── Backend API ───────────────────────────────────────────────────────────────
# Point to your deployed Express backend URL (with /api suffix)
# Local dev:   http://localhost:5000/api
# Production:  https://minicloud-api.onrender.com/api
VITE_API_BASE_URL=http://localhost:5000/api
